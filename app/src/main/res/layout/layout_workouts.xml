<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D0D0D"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Back button -->
            <pl.droidsonroids.gif.GifImageView
                android:id="@+id/gifImageView"

                android:layout_width="128dp"
                android:layout_height="59dp"
                android:src="@drawable/gif" />

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#0D0D0D"
                android:text="← Back"
                android:textColor="#80FFFFFF"
                android:textSize="14sp" />

            <!-- Push Day badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PUSH DAY"
                android:textColor="#1E88E5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="#331E88E5"
                android:layout_marginBottom="12dp" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upper Body Blast"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chest · Shoulders · Triceps"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- Meta row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ 45 min"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 380 kcal"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏋️ 8 exercises"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Progress bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:background="#1AFFFFFF"
                    android:layout_marginEnd="12dp">

                    <View
                        android:id="@+id/progress_fill"
                        android:layout_width="25dp"
                        android:layout_height="6dp"
                        android:background="#E53935"
                        android:layout_gravity="start" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2/8"
                    android:textColor="#66FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Muscle group filter -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="#E53935"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chest"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="#1AFFFFFF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shoulders"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="#1AFFFFFF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Triceps"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="#1AFFFFFF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rear Delts"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:background="#1AFFFFFF" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Exercise rows -->

        <!-- Exercise 1 (done) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✓"
                android:textColor="#1E88E5"
                android:textSize="18sp"
                android:gravity="center"
                android:background="#221E88E5"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bench Press"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 sets · 8–10 reps · Rest 90s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chest ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 2 (done) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✓"
                android:textColor="#1E88E5"
                android:textSize="18sp"
                android:gravity="center"
                android:background="#221E88E5"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incline Dumbbell Press"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sets · 10–12 reps · Rest 60s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chest ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="3"
                android:textColor="#4DFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overhead Press"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 sets · 8 reps · Rest 90s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shoulders ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="4"
                android:textColor="#4DFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lateral Raises"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sets · 15 reps · Rest 45s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shoulders ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="5"
                android:textColor="#4DFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tricep Pushdown"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sets · 12–15 reps · Rest 45s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triceps ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="6"
                android:textColor="#4DFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skull Crushers"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sets · 10 reps · Rest 60s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triceps ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="7"
                android:textColor="#4DFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cable Flyes"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sets · 12–15 reps · Rest 45s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chest ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Exercise 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0AFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="8"
                android:textColor="#4DFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#1AFFFFFF"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Face Pulls"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 sets · 15 reps · Rest 45s"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rear Delts ›"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Start Workout button (pinned to bottom via padding) -->
        <Button
            android:id="@+id/btn_start_workout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Start Workout"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#E53935"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>